{
    "name": "gardi/mcp-laravel",
    "description": "An MCP server that lets AI agents inspect a Laravel app — routes, models, schema, and read-only queries — over stdio.",
    "keywords": ["laravel", "mcp", "model-context-protocol", "ai", "agents"],
    "license": "MIT",
    "authors": [
        { "name": "Nariman Gardi", "email": "narimanmuhsin0@gmail.com" }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/routing": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "symfony/finder": "^7.0|^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": { "Gardi\\McpLaravel\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Gardi\\McpLaravel\\Tests\\": "tests/" }
    },
    "extra": {
        "laravel": {
            "providers": ["Gardi\\McpLaravel\\McpServiceProvider"]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": { "pestphp/pest-plugin": true }
    }
}
